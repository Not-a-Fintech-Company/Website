---
// src/layouts/ArticleLayout.astro
import BaseLayout from './BaseLayout.astro';
import Header from '../components/layout/Header.astro';
import MobileMenu from '../components/layout/MobileMenu.astro';
import Footer from '../components/layout/Footer.astro';
import Breadcrumbs from '../components/nav/Breadcrumbs.astro';
import Sidebar from '../components/nav/Sidebar.astro';
import Toc from '../components/nav/Toc.astro';
import Prose from '../components/ui/Prose.astro';
import type { MarkdownHeading } from 'astro';

interface Author {
  name: string;
  url?: string;
}
interface Props {
  title: string;
  description: string;
  section?: string;
  slug: string;
  headings: MarkdownHeading[];
  ogImage?: string;
  hideToc?: boolean;
  hideSidebar?: boolean;
  publishedAt?: Date;
  updatedAt?: Date;
  authors?: Author[];
}
const {
  title, description, section, slug, headings,
  ogImage, hideToc = false, hideSidebar = false,
  publishedAt, updatedAt, authors,
} = Astro.props;

const sectionLabel = section
  ? section.charAt(0).toUpperCase() + section.slice(1)
  : null;

const crumbs = [
  { label: 'Home', href: '/' },
  ...(section ? [{ label: sectionLabel!, href: `/${section}/` }] : []),
  { label: title },
];

const showSidebar = !hideSidebar && !!section;
const showToc = !hideToc;

const siteUrl = Astro.site!.toString().replace(/\/$/, '');
const canonicalUrl = new URL(Astro.url.pathname, Astro.site).toString();
const ogImagePath = ogImage ?? '/og-image.png';
const ogImageAbsolute = ogImagePath.startsWith('http')
  ? ogImagePath
  : new URL(ogImagePath, Astro.site).toString();

const authorSchema = authors?.map((a) => ({
  '@type': 'Person',
  name: a.name,
  ...(a.url ? { url: a.url } : {}),
}));

const articleSchema = publishedAt
  ? {
      '@context': 'https://schema.org',
      '@type': 'Article',
      headline: title,
      description,
      url: canonicalUrl,
      image: ogImageAbsolute,
      datePublished: publishedAt.toISOString(),
      dateModified: (updatedAt ?? publishedAt).toISOString(),
      ...(authorSchema && authorSchema.length > 0 ? { author: authorSchema } : {}),
      publisher: { '@id': `${siteUrl}/#organization` },
      isPartOf: { '@id': `${siteUrl}/#website` },
      mainEntityOfPage: canonicalUrl,
      inLanguage: 'en-US',
      license: 'https://creativecommons.org/publicdomain/zero/1.0/',
    }
  : null;
---

<BaseLayout
  {title}
  {description}
  {ogImage}
  pageType="article"
  publishedTime={publishedAt}
  modifiedTime={updatedAt ?? publishedAt}
  schema={articleSchema ?? undefined}
>
  <Header />
  <MobileMenu />

  <main id="main" class="flex-1 max-w-7xl w-full mx-auto px-4 md:px-6 py-8 md:py-12">
    <div class:list={[
      'grid gap-8 lg:gap-12',
      showSidebar && showToc ? 'lg:grid-cols-[14rem_minmax(0,1fr)] xl:grid-cols-[14rem_minmax(0,1fr)_14rem]' :
      showSidebar ? 'lg:grid-cols-[14rem_minmax(0,1fr)]' :
      showToc ? 'xl:grid-cols-[minmax(0,1fr)_14rem]' :
      ''
    ]}>
      {showSidebar && section && <Sidebar {section} currentSlug={slug} />}

      <article class="min-w-0">
        <Breadcrumbs crumbs={crumbs} />
        <h1 class="mt-4 font-display text-4xl md:text-6xl font-bold tracking-[-0.025em] text-ink leading-[1.05]">
          {title}
        </h1>
        {description && (
          <p class="mt-5 text-lg text-ink/80 max-w-prose leading-relaxed">{description}</p>
        )}
        {authors && authors.length > 0 && (
          <p class="mt-5 text-sm text-muted">
            By{' '}
            {authors.map((a, i) => (
              <>
                {i > 0 && (i === authors.length - 1 ? ' and ' : ', ')}
                {a.url ? (
                  <a href={a.url} rel="author noopener noreferrer" target="_blank" class="text-ink hover:text-accent transition-colors">{a.name}</a>
                ) : (
                  <span class="text-ink">{a.name}</span>
                )}
              </>
            ))}
          </p>
        )}
        {(publishedAt || updatedAt) && (
          <p class="mt-3 text-xs text-muted">
            {publishedAt && <span>Published {publishedAt.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</span>}
            {updatedAt && <span class="ml-2">· Updated {updatedAt.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</span>}
          </p>
        )}

        <hr class="mt-8 border-rule" />

        <Prose class="mt-8">
          <slot />
        </Prose>
      </article>

      {showToc && <Toc {headings} />}
    </div>
  </main>

  <Footer />
</BaseLayout>
